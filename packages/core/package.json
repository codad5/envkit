{
  "name": "envkit-core",
  "version": "0.1.0",
  "description": "Typed, schema-driven environment variable management",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/codad5/envkit.git",
    "directory": "packages/core"
  },
  "homepage": "https://github.com/codad5/envkit#readme",
  "bugs": "https://github.com/codad5/envkit/issues",
  "keywords": ["env", "environment", "dotenv", "validation", "typescript", "schema", "zod"],
  "publishConfig": {
    "access": "public"
  },
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "clean": "rimraf dist"
  },
  "peerDependencies": {
    "zod": ">=3.0.0"
  },
  "peerDependenciesMeta": {
    "zod": {
      "optional": true
    }
  },
  "dependencies": {
    "dotenv": "^17.4.2"
  },
  "devDependencies": {
    "@types/node": "^25.9.1"
  }
}
