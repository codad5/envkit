{
  "name": "envkit",
  "version": "0.1.0",
  "description": "CLI tool for typed environment variable management",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/codad5/envkit.git",
    "directory": "packages/cli"
  },
  "homepage": "https://github.com/codad5/envkit#readme",
  "bugs": "https://github.com/codad5/envkit/issues",
  "keywords": ["env", "environment", "dotenv", "cli", "setup", "wizard", "typescript", "validation"],
  "publishConfig": {
    "access": "public"
  },
  "type": "module",
  "bin": {
    "envkit": "./dist/index.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "clean": "rimraf dist"
  },
  "dependencies": {
    "envkit-core": "workspace:*",
    "@inquirer/prompts": "^8.5.2",
    "chalk": "^5.6.2",
    "commander": "^15.0.0",
    "jiti": "^2.7.0",
    "ora": "^9.4.0"
  },
  "devDependencies": {
    "@types/node": "^25.9.1"
  }
}
